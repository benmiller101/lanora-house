import { useState } from "react";
import { useLocation } from "wouter";
import { Helmet } from "react-helmet";
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";
import { apiRequest } from "@/lib/queryClient";
import { z } from "zod";
import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { format } from "date-fns";
import { ProductForm } from "@/components/admin/ProductForm";
import { ImageUploader } from "@/components/admin/ImageUploader";
import { AdminNavigation } from "@/components/admin/AdminNavigation";
import {
  FiPlus,
  FiEdit2,
  FiTrash2,
  FiEye,
  FiPackage,
  FiArrowLeft,
  FiShoppingBag,
  FiDollarSign,
  FiImage,
  FiTag,
  FiGrid,
  FiCalendar,
  FiClock,
  FiMapPin,
  FiInfo
} from "react-icons/fi";

import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import {
  Table,
  TableBody,
  TableCaption,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
  DialogClose,
} from "@/components/ui/dialog";
import {
  Form,
  FormControl,
  FormDescription,
  FormField,
  FormItem,
  FormLabel,
  FormMessage,
} from "@/components/ui/form";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { useToast } from "@/hooks/use-toast";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "@/components/ui/tabs";
import { Badge } from "@/components/ui/badge";
import { Label } from "@/components/ui/label";
import { Separator } from "@/components/ui/separator";
import { Checkbox } from "@/components/ui/checkbox";

// Define product schema
const productSchema = z.object({
  name: z.string().min(3, "Product name must be at least 3 characters"),
  description: z.string().min(10, "Description must be at least 10 characters"),
  detailedDescription: z.string().optional(),
  price: z.string().min(1, "Price is required"),
  originalPrice: z.string().optional(),
  categoryId: z.string().min(1, "Category is required"),
  era: z.string().min(1, "Era is required"),
  condition: z.string().min(1, "Condition is required"),
  materials: z.string().min(1, "Materials are required"),
  dimensions: z.string().optional(),
  origin: z.string().optional(),
  sku: z.string().optional(),
  provenance: z.string().optional(),
  imageUrl: z.string().min(1, "Image is required"),
  additionalImages: z.string().optional(),
  inStock: z.boolean().default(true),
  stockQuantity: z.string().min(1, "Stock quantity is required"),
  isFeatured: z.boolean().default(false),
  isBestSeller: z.boolean().default(false),
});

type ProductFormValues = z.infer<typeof productSchema>;

type Product = {
  id: string;
  name: string;
  description: string;
  detailedDescription?: string;
  price: number;
  originalPrice?: number;
  categoryId: string;
  categoryName: string;
  era: string;
  condition: string;
  materials: string[];
  dimensions?: string;
  origin?: string;
  sku?: string;
  isFeatured: boolean;
  isBestSeller: boolean;
  imageUrl: string;
  additionalImages?: string[];
  provenance?: string;
  inStock: boolean;
  stockQuantity: number;
  createdAt: string;
};

type Category = {
  id: string;
  name: string;
  slug: string;
  description?: string;
  imageUrl?: string;
};

export default function ProductsPage() {
  const [, setLocation] = useLocation();
  const { toast } = useToast();
  const queryClient = useQueryClient();
  
  const [searchTerm, setSearchTerm] = useState("");
  const [categoryFilter, setCategoryFilter] = useState("all");
  const [statusFilter, setStatusFilter] = useState("all");
  const [isCreateDialogOpen, setIsCreateDialogOpen] = useState(false);
  const [isEditDialogOpen, setIsEditDialogOpen] = useState(false);
  const [isDeleteDialogOpen, setIsDeleteDialogOpen] = useState(false);
  const [isViewDialogOpen, setIsViewDialogOpen] = useState(false);
  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);
  
  // Fetch products
  const {
    data,
    isLoading: isLoadingProducts, 
    error: productsError,
    refetch: refetchProducts
  } = useQuery({
    queryKey: ["/api/products/admin"],
    enabled: true,
    // Force refresh when the component is focused
    refetchOnWindowFocus: true,
    staleTime: 0, // Consider data stale immediately to force refresh
  });
  
  // Extract products from the response properly
  const products = data?.products || [];
  
  // Fetch categories
  const {
    data: categories = [],
    isLoading: isLoadingCategories,
    error: categoriesError,
  } = useQuery({
    queryKey: ["/api/categories"],
    enabled: true,
  });
  
  // Create form
  const form = useForm<ProductFormValues>({
    resolver: zodResolver(productSchema),
    defaultValues: {
      name: "",
      description: "",
      detailedDescription: "",
      price: "",
      originalPrice: "",
      categoryId: "",
      era: "",
      condition: "",
      materials: "",
      dimensions: "",
      origin: "",
      sku: "",
      provenance: "",
      imageUrl: "",
      additionalImages: "",
      inStock: true,
      stockQuantity: "1",
      isFeatured: false,
      isBestSeller: false,
    },
  });
  
  // Create product mutation
  const createMutation = useMutation({
    mutationFn: (data: ProductFormValues) => {
      // Convert materials from comma-separated to array
      const formattedData = {
        ...data,
        materials: data.materials.split(',').map(m => m.trim()),
        additionalImages: data.additionalImages ? data.additionalImages.split(',').map(img => img.trim()) : [],
        price: parseFloat(data.price),
        originalPrice: data.originalPrice ? parseFloat(data.originalPrice) : undefined,
        stockQuantity: parseInt(data.stockQuantity),
        sku: data.sku || undefined,
      };
      
      return apiRequest("POST", "/api/products", formattedData);
    },
    onSuccess: () => {
      toast({
        title: "Product created",
        description: "Product has been created successfully.",
      });
      queryClient.invalidateQueries({ queryKey: ["/api/products/admin"] });
      setIsCreateDialogOpen(false);
      form.reset();
    },
    onError: (error) => {
      toast({
        title: "Error",
        description: "Failed to create product: " + (error as Error).message,
        variant: "destructive",
      });
    },
  });
  
  // Update product mutation
  const updateMutation = useMutation({
    mutationFn: (data: { id: string; formData: ProductFormValues }) => {
      const { id, formData } = data;
      
      // Convert materials from comma-separated to array
      const formattedData = {
        ...formData,
        categoryId: formData.categoryId, // Ensure categoryId is included and not modified
        materials: typeof formData.materials === 'string' ? formData.materials.split(',').map(m => m.trim()) : formData.materials,
        additionalImages: typeof formData.additionalImages === 'string' && formData.additionalImages 
          ? formData.additionalImages.split(',').map(img => img.trim()) 
          : formData.additionalImages || [],
        price: parseFloat(formData.price),
        originalPrice: formData.originalPrice ? parseFloat(formData.originalPrice) : undefined,
        stockQuantity: parseInt(formData.stockQuantity),
        sku: formData.sku || undefined,
      };
      
      return apiRequest("PATCH", `/api/products/${id}`, formattedData);
    },
    onSuccess: () => {
      toast({
        title: "Product updated",
        description: "Product has been updated successfully.",
      });
      queryClient.invalidateQueries({ queryKey: ["/api/products/admin"] });
      setIsEditDialogOpen(false);
    },
    onError: (error) => {
      toast({
        title: "Error",
        description: "Failed to update product: " + (error as Error).message,
        variant: "destructive",
      });
    },
  });
  
  // Delete product mutation
  const deleteMutation = useMutation({
    mutationFn: (id: string) => apiRequest("DELETE", `/api/products/${id}`),
    onSuccess: () => {
      toast({
        title: "Product deleted",
        description: "Product has been deleted successfully.",
      });
      queryClient.invalidateQueries({ queryKey: ["/api/products/admin"] });
      setIsDeleteDialogOpen(false);
    },
    onError: (error) => {
      toast({
        title: "Error",
        description: "Failed to delete product: " + (error as Error).message,
        variant: "destructive",
      });
    },
  });
  
  // Handle form submission for creating a new product
  const onCreateSubmit = (data: ProductFormValues) => {
    createMutation.mutate(data);
  };
  
  // Filter products
  const filteredProducts = Array.isArray(products) ? products.filter((product: Product) => {
    // Filter by search term
    const matchesSearch =
      searchTerm === "" ||
      product.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
      product.description.toLowerCase().includes(searchTerm.toLowerCase());
    
    // Filter by category
    const matchesCategory =
      categoryFilter === "all" || product.categoryId === categoryFilter;
    
    // Filter by status
    const matchesStatus =
      statusFilter === "all" ||
      (statusFilter === "inStock" && product.inStock) ||
      (statusFilter === "outOfStock" && !product.inStock) ||
      (statusFilter === "featured" && product.isFeatured) ||
      (statusFilter === "bestSeller" && product.isBestSeller);
    
    return matchesSearch && matchesCategory && matchesStatus;
  }) : [];
  
  // Handle search form submission
  const handleSearch = (e: React.FormEvent) => {
    e.preventDefault();
  };
  
  // Handle clicking on the edit button
  const handleEdit = (product: Product) => {
    setSelectedProduct(product);
    setIsEditDialogOpen(true);
  };
  
  // Handle clicking on the delete button
  const handleDelete = (product: Product) => {
    setSelectedProduct(product);
    setIsDeleteDialogOpen(true);
  };
  
  // Handle clicking on the view button
  const handleView = (product: Product) => {
    setSelectedProduct(product);
    setIsViewDialogOpen(true);
  };
  
  // Handle going to product details page in store
  const handleViewInStore = (productId: string) => {
    setLocation(`/product-details?id=${productId}`);
  };
  
  // Format currency
  const formatPrice = (price: number) => {
    return `£${price.toFixed(2)}`;
  };
  
  // Format date
  const formatDate = (dateStr: string) => {
    try {
      return format(new Date(dateStr), "dd MMM yyyy");
    } catch (e) {
      return dateStr;
    }
  };
  
  // Display a loading state if products or categories are loading
  if (isLoadingProducts || isLoadingCategories) {
    return (
      <div className="flex justify-center items-center min-h-screen">
        <div className="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-primary"></div>
      </div>
    );
  }
  
  // Display an error if there was an error loading products or categories
  if (productsError || categoriesError) {
    return (
      <div className="flex justify-center items-center min-h-screen">
        <div className="text-center">
          <h2 className="text-2xl font-bold text-red-600 mb-3">Error</h2>
          <p className="text-gray-700">
            {(productsError as Error)?.message || (categoriesError as Error)?.message || "Failed to load data"}
          </p>
          <Button
            className="mt-4"
            onClick={() => queryClient.invalidateQueries({ queryKey: ["/api/products/admin"] })}
          >
            Try Again
          </Button>
        </div>
      </div>
    );
  }
  
  return (
    <>
      <Helmet>
        <title>Products | Admin Dashboard | Lanora House</title>
      </Helmet>
      
      <div className="container mx-auto py-6 max-w-7xl">
        <AdminNavigation />
        
        <div className="px-4 py-4">
          <div className="flex justify-between items-center mb-8">
            <div>
              <h1 className="text-3xl font-bold">Products</h1>
              <p className="text-gray-500">Manage your store products</p>
            </div>
            
            <Button onClick={() => setIsCreateDialogOpen(true)}>
              <FiPlus className="mr-2 h-4 w-4" /> Add Product
            </Button>
          </div>
        
          <Card className="mb-8">
            <CardHeader className="pb-3">
              <CardTitle>Product Filters</CardTitle>
              <CardDescription>Filter and search your products</CardDescription>
            </CardHeader>
            <CardContent>
            <div className="flex flex-col sm:flex-row gap-4 items-start sm:items-end">
              <div className="w-full sm:w-auto space-y-2">
                <Label htmlFor="search">Search Products</Label>
                <form onSubmit={handleSearch} className="flex w-full sm:w-auto gap-2">
                  <Input
                    id="search"
                    placeholder="Search by name or description..."
                    value={searchTerm}
                    onChange={(e) => setSearchTerm(e.target.value)}
                    className="w-full sm:w-80"
                  />
                  <Button type="submit" variant="secondary">
                    Search
                  </Button>
                </form>
              </div>
              
              <div className="w-full sm:w-auto space-y-2">
                <Label htmlFor="category-filter">Category</Label>
                <Select
                  value={categoryFilter}
                  onValueChange={setCategoryFilter}
                >
                  <SelectTrigger id="category-filter" className="w-full sm:w-48">
                    <SelectValue placeholder="All Categories" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">All Categories</SelectItem>
                    {categories.map((category: Category) => (
                      <SelectItem key={category.id} value={category.id}>
                        {category.name}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              
              <div className="w-full sm:w-auto space-y-2">
                <Label htmlFor="status-filter">Status</Label>
                <Select
                  value={statusFilter}
                  onValueChange={setStatusFilter}
                >
                  <SelectTrigger id="status-filter" className="w-full sm:w-48">
                    <SelectValue placeholder="All Products" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">All Products</SelectItem>
                    <SelectItem value="inStock">In Stock</SelectItem>
                    <SelectItem value="outOfStock">Out of Stock</SelectItem>
                    <SelectItem value="featured">Featured</SelectItem>
                    <SelectItem value="bestSeller">Best Seller</SelectItem>
                  </SelectContent>
                </Select>
              </div>
              
              <Button
                variant="outline"
                onClick={() => {
                  setSearchTerm("");
                  setCategoryFilter("all");
                  setStatusFilter("all");
                }}
              >
                Reset Filters
              </Button>
            </div>
          </CardContent>
        </Card>
        
        <Card>
          <CardHeader className="pb-3">
            <CardTitle>Product List</CardTitle>
            <CardDescription>
              Showing {filteredProducts.length} of {products.length} products
            </CardDescription>
          </CardHeader>
          <CardContent>
            <div className="rounded-md border overflow-hidden">
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead className="w-[80px]">Image</TableHead>
                    <TableHead className="w-[200px]">Name</TableHead>
                    <TableHead>Category</TableHead>
                    <TableHead className="text-right">Price</TableHead>
                    <TableHead>Status</TableHead>
                    <TableHead className="text-center">Added</TableHead>
                    <TableHead className="text-right">Actions</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {filteredProducts.length === 0 ? (
                    <TableRow>
                      <TableCell colSpan={7} className="text-center py-8 text-gray-500">
                        No products found
                      </TableCell>
                    </TableRow>
                  ) : (
                    filteredProducts.map((product: Product) => (
                      <TableRow key={product.id}>
                        <TableCell>
                          <div className="relative h-16 w-16 rounded-md overflow-hidden border">
                            <img
                              src={product.imageUrl}
                              alt={product.name}
                              className="object-cover h-full w-full"
                            />
                          </div>
                        </TableCell>
                        <TableCell className="font-medium">
                          <div className="flex flex-col">
                            <span className="text-sm font-semibold">
                              {product.name}
                            </span>
                            <span className="text-xs text-gray-500 truncate max-w-[200px]">
                              {product.sku || "No SKU"}
                            </span>
                          </div>
                        </TableCell>
                        <TableCell>
                          <Badge variant="outline">{product.categoryName}</Badge>
                        </TableCell>
                        <TableCell className="text-right">
                          <div className="flex flex-col items-end">
                            <span className="font-medium">
                              {formatPrice(product.price)}
                            </span>
                            {product.originalPrice && (
                              <span className="text-xs text-gray-500 line-through">
                                {formatPrice(product.originalPrice)}
                              </span>
                            )}
                          </div>
                        </TableCell>
                        <TableCell>
                          <div className="flex flex-col gap-1">
                            {product.inStock ? (
                              <Badge variant="outline" className="bg-green-50 text-green-600 border-green-200">
                                In Stock ({product.stockQuantity})
                              </Badge>
                            ) : (
                              <Badge variant="outline" className="bg-red-50 text-red-600 border-red-200">
                                Out of Stock
                              </Badge>
                            )}
                            {product.isFeatured && (
                              <Badge variant="outline" className="bg-purple-50 text-purple-600 border-purple-200">
                                Featured
                              </Badge>
                            )}
                            {product.isBestSeller && (
                              <Badge variant="outline" className="bg-amber-50 text-amber-600 border-amber-200">
                                Best Seller
                              </Badge>
                            )}
                          </div>
                        </TableCell>
                        <TableCell className="text-center">
                          {formatDate(product.createdAt)}
                        </TableCell>
                        <TableCell className="text-right">
                          <div className="flex justify-end space-x-2">
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleView(product)}
                            >
                              <FiEye className="h-4 w-4" />
                            </Button>
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleEdit(product)}
                            >
                              <FiEdit2 className="h-4 w-4" />
                            </Button>
                            <Button
                              variant="outline"
                              size="sm"
                              onClick={() => handleDelete(product)}
                              className="text-red-500 hover:text-red-700"
                            >
                              <FiTrash2 className="h-4 w-4" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))
                  )}
                </TableBody>
              </Table>
            </div>
          </CardContent>
        </Card>
      </div>
      
      {/* Create Product Dialog */}
      <Dialog open={isCreateDialogOpen} onOpenChange={setIsCreateDialogOpen}>
        <DialogContent className="sm:max-w-[800px]">
          <DialogHeader>
            <DialogTitle>Create New Product</DialogTitle>
            <DialogDescription>Add a new product to your store.</DialogDescription>
          </DialogHeader>
          
          <ProductForm 
            categories={categories} 
            onSuccess={() => {
              setIsCreateDialogOpen(false);
              queryClient.invalidateQueries({queryKey: ['/api/products/admin']});
            }}
          />
        </DialogContent>
      </Dialog>
      
      {/* Edit Product Dialog */}
      <Dialog open={isEditDialogOpen} onOpenChange={setIsEditDialogOpen}>
        <DialogContent className="sm:max-w-[800px]">
          <DialogHeader>
            <DialogTitle>Edit Product</DialogTitle>
            <DialogDescription>Update product details.</DialogDescription>
          </DialogHeader>
          
          {selectedProduct && (
            <ProductForm 
              initialValues={{
                ...selectedProduct,
                materials: Array.isArray(selectedProduct.materials) ? selectedProduct.materials.join(', ') : selectedProduct.materials,
                additionalImages: Array.isArray(selectedProduct.additionalImages) ? selectedProduct.additionalImages.join(', ') : selectedProduct.additionalImages,
                price: selectedProduct.price.toString(),
                originalPrice: selectedProduct.originalPrice ? selectedProduct.originalPrice.toString() : '',
                stockQuantity: selectedProduct.stockQuantity.toString()
              }}
              categories={categories} 
              onSuccess={() => {
                setIsEditDialogOpen(false);
                // Invalidate all product queries and then force immediate refetch
                queryClient.invalidateQueries({queryKey: ['/api/products/admin']});
                queryClient.invalidateQueries({queryKey: ['/api/products']});
                // Force immediate refresh of the products list
                setTimeout(() => {
                  refetchProducts();
                }, 300);
              }}
              isEditing={true}
            />
          )}
        </DialogContent>
      </Dialog>
      
      {/* Delete Confirmation Dialog */}
      <Dialog open={isDeleteDialogOpen} onOpenChange={setIsDeleteDialogOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Delete Product</DialogTitle>
            <DialogDescription>
              Are you sure you want to delete this product? This action cannot be undone.
            </DialogDescription>
          </DialogHeader>
          
          {selectedProduct && (
            <div className="flex flex-col space-y-4 mt-2">
              <div className="flex items-center space-x-4">
                <div className="relative h-16 w-16 rounded-md overflow-hidden border">
                  <img
                    src={selectedProduct.imageUrl}
                    alt={selectedProduct.name}
                    className="object-cover h-full w-full"
                  />
                </div>
                <div>
                  <h3 className="font-semibold">{selectedProduct.name}</h3>
                  <p className="text-sm text-gray-500">{formatPrice(selectedProduct.price)}</p>
                </div>
              </div>
              
              <DialogFooter>
                <Button
                  variant="outline"
                  onClick={() => setIsDeleteDialogOpen(false)}
                >
                  Cancel
                </Button>
                <Button
                  variant="destructive"
                  onClick={() => deleteMutation.mutate(selectedProduct.id)}
                  disabled={deleteMutation.isPending}
                >
                  {deleteMutation.isPending ? "Deleting..." : "Delete Product"}
                </Button>
              </DialogFooter>
            </div>
          )}
        </DialogContent>
      </Dialog>
      
      {/* View Product Details Dialog */}
      <Dialog open={isViewDialogOpen} onOpenChange={setIsViewDialogOpen}>
        <DialogContent className="sm:max-w-[800px]">
          <DialogHeader>
            <DialogTitle>Product Details</DialogTitle>
          </DialogHeader>
          
          {selectedProduct && (
            <div>
              <div className="flex flex-col md:flex-row gap-6">
                <div className="w-full md:w-1/3 space-y-4">
                  <div className="rounded-md overflow-hidden border">
                    <img
                      src={selectedProduct.imageUrl}
                      alt={selectedProduct.name}
                      className="object-cover w-full aspect-square"
                    />
                  </div>
                  
                  {selectedProduct.additionalImages && selectedProduct.additionalImages.length > 0 && (
                    <div className="grid grid-cols-3 gap-2">
                      {selectedProduct.additionalImages.map((img, idx) => (
                        <div key={idx} className="rounded-md overflow-hidden border">
                          <img
                            src={img}
                            alt={`${selectedProduct.name} ${idx + 1}`}
                            className="object-cover w-full aspect-square"
                          />
                        </div>
                      ))}
                    </div>
                  )}
                </div>
                
                <div className="w-full md:w-2/3">
                  <div className="space-y-6">
                    <div>
                      <h2 className="text-2xl font-bold">{selectedProduct.name}</h2>
                      {selectedProduct.sku && (
                        <p className="text-sm text-gray-500">SKU: {selectedProduct.sku}</p>
                      )}
                      <div className="flex items-center mt-2 gap-2">
                        <Badge variant="outline" className="bg-gray-100">
                          {selectedProduct.categoryName}
                        </Badge>
                        {selectedProduct.isFeatured && (
                          <Badge variant="outline" className="bg-purple-50 text-purple-600 border-purple-200">
                            Featured
                          </Badge>
                        )}
                        {selectedProduct.isBestSeller && (
                          <Badge variant="outline" className="bg-amber-50 text-amber-600 border-amber-200">
                            Best Seller
                          </Badge>
                        )}
                      </div>
                    </div>
                    
                    <div className="flex items-end gap-2">
                      <span className="text-2xl font-bold">
                        {formatPrice(selectedProduct.price)}
                      </span>
                      {selectedProduct.originalPrice && (
                        <span className="text-lg text-gray-500 line-through">
                          {formatPrice(selectedProduct.originalPrice)}
                        </span>
                      )}
                    </div>
                    
                    <Separator />
                    
                    <div className="grid grid-cols-2 gap-y-4 text-sm">
                      <div>
                        <span className="font-medium flex items-center gap-1">
                          <FiPackage className="h-4 w-4" /> Stock Status:
                        </span>
                        <span>
                          {selectedProduct.inStock
                            ? `In Stock (${selectedProduct.stockQuantity})`
                            : "Out of Stock"}
                        </span>
                      </div>
                      
                      <div>
                        <span className="font-medium flex items-center gap-1">
                          <FiClock className="h-4 w-4" /> Era:
                        </span>
                        <span>{selectedProduct.era}</span>
                      </div>
                      
                      <div>
                        <span className="font-medium flex items-center gap-1">
                          <FiInfo className="h-4 w-4" /> Condition:
                        </span>
                        <span>{selectedProduct.condition}</span>
                      </div>
                      
                      <div>
                        <span className="font-medium flex items-center gap-1">
                          <FiMapPin className="h-4 w-4" /> Origin:
                        </span>
                        <span>{selectedProduct.origin || "Not specified"}</span>
                      </div>
                      
                      {selectedProduct.dimensions && (
                        <div>
                          <span className="font-medium flex items-center gap-1">
                            <FiGrid className="h-4 w-4" /> Dimensions:
                          </span>
                          <span>{selectedProduct.dimensions}</span>
                        </div>
                      )}
                      
                      <div>
                        <span className="font-medium flex items-center gap-1">
                          <FiCalendar className="h-4 w-4" /> Added:
                        </span>
                        <span>{formatDate(selectedProduct.createdAt)}</span>
                      </div>
                    </div>
                    
                    <Separator />
                    
                    <div>
                      <h3 className="font-medium mb-2">Description</h3>
                      <p className="text-gray-700 text-sm">{selectedProduct.description}</p>
                    </div>
                    
                    {selectedProduct.detailedDescription && (
                      <div>
                        <h3 className="font-medium mb-2">Detailed Description</h3>
                        <p className="text-gray-700 text-sm">{selectedProduct.detailedDescription}</p>
                      </div>
                    )}
                    
                    {selectedProduct.materials && selectedProduct.materials.length > 0 && (
                      <div>
                        <h3 className="font-medium mb-2">Materials</h3>
                        <div className="flex flex-wrap gap-2">
                          {selectedProduct.materials.map((material, idx) => (
                            <Badge key={idx} variant="outline">
                              {material}
                            </Badge>
                          ))}
                        </div>
                      </div>
                    )}
                    
                    {selectedProduct.provenance && (
                      <div>
                        <h3 className="font-medium mb-2">Provenance</h3>
                        <p className="text-gray-700 text-sm">{selectedProduct.provenance}</p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
              
              <DialogFooter className="mt-6 gap-2 flex-wrap">
                <Button 
                  variant="outline" 
                  onClick={() => handleViewInStore(selectedProduct.id)}
                  className="flex items-center"
                >
                  <FiEye className="mr-2" /> View in Store
                </Button>
                <Button 
                  variant="outline" 
                  onClick={() => {
                    setIsViewDialogOpen(false);
                    handleEdit(selectedProduct);
                  }}
                  className="flex items-center"
                >
                  <FiEdit2 className="mr-2" /> Edit Product
                </Button>
                <Button
                  variant="destructive"
                  onClick={() => {
                    setIsViewDialogOpen(false);
                    handleDelete(selectedProduct);
                  }}
                  className="flex items-center"
                >
                  <FiTrash2 className="mr-2" /> Delete Product
                </Button>
              </DialogFooter>
            </div>
          )}
        </DialogContent>
      </Dialog>
    </>
  );
}